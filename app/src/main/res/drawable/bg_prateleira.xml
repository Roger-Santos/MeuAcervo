<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sombra superior (suave) -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#22000000"
                android:centerColor="#11000000"
                android:endColor="@android:color/transparent"
                android:angle="90"/>
            <size android:height="6dp" />
        </shape>
    </item>

    <!-- corpo da tábua (madeira) -->
    <item android:top="4dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#D0A56A"/>               <!-- tom base madeira -->
            <stroke android:width="1dp" android:color="#AE8A55"/> <!-- borda -->
            <corners android:radius="4dp"/>
        </shape>
    </item>

    <!-- textura sutil usando linhas horizontais (criado com size e inset para repetir visual) -->
    <item android:top="8dp">
        <shape android:shape="rectangle">
            <size android:height="1dp"/>
            <solid android:color="#00000000"/>
            <stroke android:width="1dp" android:color="#00000000" />
        </shape>
    </item>

</layer-list>