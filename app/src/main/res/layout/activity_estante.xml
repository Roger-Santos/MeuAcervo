<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootEstante"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- AppBar flat (sem sombra) com toolbar branca e pills de navegação -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/backgroundColor"
        app:elevation="0dp">

        <!-- Toolbar minimalista -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarEstante"
            style="@style/Toolbar.Minimalista"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/titulo_estante"
            app:navigationIcon="@drawable/ic_arrow_back"/>

        <!-- Pills de navegação substituindo o TabLayout -->
        <!-- Mantém o id tabLayout para não quebrar o TabLayoutMediator -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/backgroundColor"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            app:tabIndicatorHeight="0dp"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="@color/colorOnPrimary"
            app:tabTextColor="@color/textSecondary"
            app:tabTextAppearance="@android:style/TextAppearance.Small"
            app:tabBackground="@drawable/bg_pill_tab"
            app:tabMode="scrollable"
            app:tabMinWidth="0dp"
            app:tabPaddingStart="16dp"
            app:tabPaddingEnd="16dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager — margem inferior reserva espaço para o banner -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_marginBottom="56dp"/>

    <!-- Banner AdMob fixo no rodapé, acima do FAB -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        ads:adSize="BANNER"
        ads:adUnitId="@string/admob_banner_estante"/>

    <!-- FAB no canto inferior direito, acima do banner -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add_book"
        android:contentDescription="@string/fab_add_item"
        app:backgroundTint="@color/primaryColor"
        app:tint="@color/colorOnPrimary"
        android:layout_margin="16dp"
        android:layout_gravity="bottom|end"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>