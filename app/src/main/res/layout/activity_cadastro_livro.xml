<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootCadastro"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/divideColor">

    <!-- Loading central -->
    <ProgressBar
        android:id="@+id/progressLoading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Toolbar + conteúdo -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/darkPrimaryColor"
            android:title="@string/titulo_cadastro_livro"
            android:titleTextColor="@color/white"
            android:elevation="4dp"
            android:theme="@style/ThemeOverlay.AppCompat.Light" />

        <!-- Conteúdo scrollável -->
        <ScrollView
            android:id="@+id/layoutConteudo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="4dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/mainLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="0dp">

                <!-- Bloco capa -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/white">

                    <TextView
                        android:id="@+id/tvCapaLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_capa"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvCapaInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/info_capa"
                        android:textSize="14sp"
                        android:textColor="@android:color/darker_gray" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/ivCapa"
                            android:layout_width="180dp"
                            android:layout_height="260dp"
                            android:layout_gravity="center"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_capa_placeholder"
                            android:contentDescription="@string/capa_livro_desc"
                            android:clickable="true"
                            android:focusable="true" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Bloco ISBN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_isbn"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/tvIsbnInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/info_isbn"
                        android:textSize="14sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginTop="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etIsbn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/hint_isbn"
                            android:background="@drawable/field_bg"
                            android:inputType="text"
                            android:imeOptions="actionDone" />

                        <ImageButton
                            android:id="@+id/btnIsbnFetch"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/primaryColor"
                            android:contentDescription="@string/btn_buscar_isbn"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            app:tint="@android:color/white"
                            app:srcCompat="@drawable/ic_refresh" />

                        <ImageButton
                            android:id="@+id/btnIsbnScan"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/primaryColor"
                            android:contentDescription="@string/btn_scan_barcode"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            app:tint="@android:color/white"
                            app:srcCompat="@drawable/ic_barcode" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Bloco palavras detectadas (oculto por padrão) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/white"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_palavras_detectadas"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvContraCapaInfo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/info_contracapa"
                            android:textSize="14sp"
                            android:textColor="@android:color/darker_gray" />

                        <ImageButton
                            android:id="@+id/btnCaptureContraCapa"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/primaryColor"
                            android:contentDescription="@string/btn_capture_contracapa"
                            android:padding="8dp"
                            app:tint="@android:color/white"
                            app:srcCompat="@drawable/ic_camera_alt" />
                    </LinearLayout>

                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/containerPalavras"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/wordsAreaBackground"
                        android:padding="12dp"
                        android:visibility="gone"
                        app:flexWrap="wrap"
                        app:justifyContent="flex_start" />
                </LinearLayout>

                <!-- Bloco rating -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/white">

                    <TextView
                        android:id="@+id/tvRatingLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_classificacao"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvRatingInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/info_classificacao"
                        android:textSize="14sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start">

                        <RatingBar
                            android:id="@+id/ratingBar"
                            style="?android:attr/ratingBarStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:isIndicator="false"
                            android:numStars="5"
                            android:rating="0"
                            android:stepSize="1.0" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Campos principais -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp">

                    <!-- Card: Título e Categoria -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_titulo_livro"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <EditText
                                android:id="@+id/etTitulo"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:hint="@string/hint_titulo_livro"
                                android:inputType="textCapWords" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_categoria"
                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:layout_marginTop="12dp" />

                            <EditText
                                android:id="@+id/etCategoria"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:hint="@string/hint_categoria"
                                android:inputType="textCapSentences" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Card: Autores, Editora, Ano, Páginas -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_autores"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <EditText
                                android:id="@+id/etAutores"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:hint="@string/hint_autores_livro"
                                android:inputType="text" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/label_editora"
                                        android:textSize="14sp"
                                        android:textColor="@color/black" />

                                    <EditText
                                        android:id="@+id/etEditora"
                                        android:layout_width="match_parent"
                                        android:layout_height="44dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/field_bg"
                                        android:padding="10dp"
                                        android:hint="@string/hint_editora"
                                        android:inputType="text" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:layout_marginStart="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/label_ano"
                                        android:textSize="14sp"
                                        android:textColor="@color/black" />

                                    <EditText
                                        android:id="@+id/etDataPublicacao"
                                        android:layout_width="96dp"
                                        android:layout_height="44dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/field_bg"
                                        android:padding="10dp"
                                        android:hint="@string/hint_ano_livro"
                                        android:inputType="number"
                                        android:maxLength="4" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:layout_marginStart="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/label_paginas"
                                        android:textSize="14sp"
                                        android:textColor="@color/black" />

                                    <EditText
                                        android:id="@+id/etPaginas"
                                        android:layout_width="80dp"
                                        android:layout_height="44dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/field_bg"
                                        android:padding="10dp"
                                        android:hint="@string/hint_paginas_livro"
                                        android:inputType="number" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Card: Descrição -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="1dp"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_descricao"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <EditText
                                android:id="@+id/etDescricao"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:minLines="4"
                                android:maxLines="8"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:gravity="top"
                                android:hint="@string/hint_descricao_livro"
                                android:inputType="textMultiLine" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Card: Palavras-chave -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_palavras_chave"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/black" />

                            <EditText
                                android:id="@+id/etPalavrasChave"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:hint="@string/hint_palavras_chave_livro"
                                android:inputType="textMultiLine"
                                android:minLines="3"
                                android:maxLines="6"
                                android:gravity="top" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Novo card: Status de leitura e Data de aquisição -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <CheckBox
                                android:id="@+id/cbJaLido"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ja_li_livro"
                                android:textColor="@color/black"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/label_data_aquisicao"
                                android:textSize="14sp"
                                android:textColor="@color/black" />

                            <!-- Configurado para abrir calendário via código (sem teclado) -->
                            <EditText
                                android:id="@+id/etDataAquisicao"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/field_bg"
                                android:padding="10dp"
                                android:hint="@string/hint_data_aquisicao"
                                android:focusable="false"
                                android:clickable="true" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- FAB móvel (envolto em CardView para arrastar) -->
    <FrameLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/fabCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            android:clickable="true"
            android:focusable="true">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSalvar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_save"
                app:tint="@android:color/white"
                app:backgroundTint="@color/primaryColor"
                android:contentDescription="@string/btn_salvar_livro"/>
        </androidx.cardview.widget.CardView>
    </FrameLayout>
</FrameLayout>