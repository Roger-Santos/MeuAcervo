<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- RecyclerView em prateleira -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEmprestimos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Mensagem de vazio -->
    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/msg_vazio_emprestimos"
        android:gravity="center"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Botão flutuante -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddEmprestimo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add_book"
        android:contentDescription="@string/fab_novo_emprestimo"
        app:backgroundTint="@color/primaryColor"
        app:tint="@android:color/white"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"/>
</FrameLayout>