<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- Toolbar minimalista -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDetalhes"
        style="@style/Toolbar.Minimalista"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title=""
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <!-- Tabs: Detalhes / Editar -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/backgroundColor"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:tabIndicatorHeight="0dp"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="@color/colorOnPrimary"
        app:tabTextColor="@color/textSecondary"
        app:tabTextAppearance="@android:style/TextAppearance.Small"
        app:tabBackground="@drawable/bg_pill_tab"
        app:tabMode="scrollable"
        app:tabPaddingStart="16dp"
        app:tabPaddingEnd="16dp"/>

    <!-- ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>