<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- Capa com altura fixa absoluta — garante uniformidade na grade -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/divideColor"
        app:strokeWidth="0.5dp">

        <ImageView
            android:id="@+id/ivCapaItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_capa_placeholder"
            android:contentDescription="@string/capa_livro_desc"/>

        <!-- Selo de lido (canto inferior direito da capa) -->
        <ImageView
            android:id="@+id/ivLido"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="@string/icon_lido_desc"
            android:visibility="gone"
            app:tint="@color/successColor"/>

    </androidx.cardview.widget.CardView>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/placeholder_titulo_livro"
        android:textColor="@color/textPrimary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2"/>

    <!-- Autor -->
    <TextView
        android:id="@+id/tvAutorItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/placeholder_autores_livro"
        android:textColor="@color/textSecondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Campos ocultos mantidos para compatibilidade com o Adapter -->
    <TextView
        android:id="@+id/tvCategoriaItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvPaginasItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <RatingBar
        android:id="@+id/ratingBarItem"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1.0"
        android:isIndicator="true"
        android:visibility="gone"/>

</LinearLayout>