<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/bg_detalhe_emprestimo">

    <!-- Ícone da pessoa -->
    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_person"
        app:tint="@color/primaryColor"
        android:layout_gravity="center_vertical"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <!-- Nome da pessoa -->
        <TextView
            android:id="@+id/tvPessoaDetalhe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_nome_pessoa"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/black"/>

        <!-- Informações adicionais -->
        <TextView
            android:id="@+id/tvInfoDetalhe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_info_emprestimo"
            android:textSize="13sp"
            android:textColor="@color/darkGray"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatusDetalhe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_em_aberto"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="@color/primaryColor"
        android:padding="4dp"
        android:background="@drawable/bg_status_chip"/>
</LinearLayout>