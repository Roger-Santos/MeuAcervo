<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEmprestimo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Imagem da capa à esquerda -->
        <ImageView
            android:id="@+id/ivCapaLivro"
            android:layout_width="100dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_capa_placeholder"
            android:contentDescription="@string/capa_livro_desc"
            android:layout_marginEnd="12dp"/>

        <!-- Informações à direita -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/tvTituloLivro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_titulo_livro"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/black"/>

            <!-- Pessoa -->
            <TextView
                android:id="@+id/tvPessoa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_emprestado_para"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <!-- Telefone -->
            <TextView
                android:id="@+id/tvTelefone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_telefone"
                android:textSize="14sp"
                android:layout_marginTop="2dp"/>

            <!-- Data prevista -->
            <TextView
                android:id="@+id/tvDataPrevista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_sem_prazo"
                android:textSize="14sp"
                android:layout_marginTop="2dp"/>

            <!-- Indicador de alarme -->
            <LinearLayout
                android:id="@+id/layoutAlarme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:id="@+id/icAlarme"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_alarm"
                    app:tint="@color/primaryColor"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvAlarme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alarme_configurado"
                    android:textSize="14sp"
                    android:textColor="@color/primaryColor"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Botão devolver -->
            <Button
                android:id="@+id/btnDevolver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_devolver"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>