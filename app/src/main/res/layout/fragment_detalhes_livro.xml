<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- Conteúdo com scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Capa centralizada grande -->

            <androidx.cardview.widget.CardView
                android:layout_width="140dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/ivCapa"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_capa_placeholder"
                    android:contentDescription="@string/capa_livro_desc"/>

            </androidx.cardview.widget.CardView>

            <!-- Título -->
            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_titulo_livro"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <!-- Autores -->
            <!-- Autores -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_autores_livro"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:textAlignment="center"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvAutores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/valor_nao_informado"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:textAlignment="center"
                android:layout_marginBottom="20dp"/>

            <!-- Stat cards: Páginas e Categoria -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_paginas"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"/>

                        <TextView
                            android:id="@+id/tvPaginas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_categoria"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"/>

                        <TextView
                            android:id="@+id/tvCategoria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Stat cards: Editora e Ano -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_editora"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"/>

                        <TextView
                            android:id="@+id/tvEditora"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_ano"
                            android:textSize="11sp"
                            android:textColor="@color/textSecondary"/>

                        <TextView
                            android:id="@+id/tvDataPublicacao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Avaliação -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_avaliacao_livro"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"/>

                <RatingBar
                    android:id="@+id/ratingBar"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1.0"
                    android:isIndicator="true"
                    android:layout_marginStart="8dp"/>

                <ImageView
                    android:id="@+id/ivLido"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/successColor"
                    android:contentDescription="@string/icon_lido_desc"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Descrição -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_descricao_livro"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvDescricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/valor_nao_informado"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="20dp"/>

            <!-- Palavras-chave -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_palavras_chave_livro"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPalavrasChave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleLine="false"
                app:chipSpacing="8dp"/>

            <!-- Data aquisição -->
            <TextView
                android:id="@+id/tvDataAquisicao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_data_aquisicao_nao_informado"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botão fixo no rodapé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/backgroundColor"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmprestar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/btn_registrar_emprestimo"
            android:textColor="@color/colorOnPrimary"
            app:backgroundTint="@color/primaryColor"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>